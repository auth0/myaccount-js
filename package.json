{
    "name": "@auth0/myaccount-js",
    "version": "1.0.0-beta.0",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/auth0/myaccount-js.git"
    },
    "license": "MIT",
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "prettier . --write --ignore-unknown",
        "format:check": "prettier . --check --ignore-unknown",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check": "pnpm format:check",
        "check:fix": "pnpm format",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire",
        "docs": "typedoc",
        "docs:watch": "typedoc --watch",
        "lint:package": "publint --pack pnpm",
        "prepare": "husky"
    },
    "dependencies": {},
    "devDependencies": {
        "webpack": "^5.105.4",
        "ts-loader": "^9.5.4",
        "vitest": "^4.1.1",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.9.3",
        "prettier": "3.8.1",
        "typedoc": "^0.28.13",
        "typedoc-plugin-missing-exports": "^4.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.4",
        "@eslint/js": "^9.37.0",
        "eslint": "^9.37.0",
        "typescript-eslint": "^8.46.1",
        "publint": "^0.3.15"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false,
    "description": "Auth0 SDK for JavaScript/TypeScript to manage user accounts, profiles, sessions, and authentication settings",
    "author": "Auth0",
    "homepage": "https://github.com/auth0/myaccount-js#readme",
    "keywords": [
        "auth0",
        "myaccount",
        "authentication",
        "authorization",
        "api",
        "sdk",
        "typescript",
        "javascript"
    ],
    "bugs": {
        "url": "https://github.com/auth0/myaccount-js/issues"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,css,md}": [
            "prettier --write"
        ]
    }
}
